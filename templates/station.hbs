<div class="sc-body">
  <div class="sc-title-row"><div><h2>{{stationName}}</h2>{{#if stationDescription}}<p>{{stationDescription}}</p>{{/if}}</div>{{#if isGM}}<button type="button" data-action="configure"><i class="fa-solid fa-gear"></i> {{localize "DOWNTIME_MANAGER.Actions.Configure"}}</button>{{/if}}</div>
  {{#if disabled}}<p class="notification warning">{{localize "DOWNTIME_MANAGER.Station.Disabled"}}</p>{{/if}}
  {{#if noActor}}<p>{{localize "DOWNTIME_MANAGER.Station.SelectCrafter"}}</p>{{else}}
    <div class="sc-summary"><span><strong>{{localize "DOWNTIME_MANAGER.Station.Crafter"}}:</strong> {{actorName}}</span><span><strong>{{localize "DOWNTIME_MANAGER.Station.Downtime"}}:</strong> {{downtime}}</span>{{#if showGold}}<span><strong>{{localize "DOWNTIME_MANAGER.Station.Gold"}}:</strong> {{gold}} {{localize "DOWNTIME_MANAGER.Currency.GP"}}</span>{{/if}}{{#if actorValueEnabled}}<span><strong>{{actorValueLabel}}:</strong> {{actorValue}}</span>{{/if}}</div>
    <h3>{{localize "DOWNTIME_MANAGER.Station.Projects"}}</h3>
    <div class="sc-list">{{#each projects}}
      <article class="sc-project {{#if completed}}completed{{/if}}">
        <div class="sc-project-main"><img src="{{img}}" alt=""><div class="sc-project-content"><div class="sc-project-heading"><strong>{{name}}</strong>{{#if personal}} · {{localize "DOWNTIME_MANAGER.Project.Personal"}}{{/if}}{{#if repeatable}} · {{localize "DOWNTIME_MANAGER.Project.Repeatable"}}{{/if}}{{#if showGoldCost}}<span class="sc-project-cost"><strong>{{localize "DOWNTIME_MANAGER.Project.UnitCost"}}:</strong> {{goldCost}} {{localize "DOWNTIME_MANAGER.Currency.GP"}}</span>{{/if}}</div>{{#if description}}<div class="notes sc-project-description">{{{description}}}</div>{{/if}}</div></div>

        <div class="sc-project-progress-actions">
          {{#if active}}<div class="sc-project-progress"><div>{{progress}} / {{requiredProgress}} ({{percent}}%)</div><progress max="{{requiredProgress}}" value="{{progress}}"></progress><small class="notes">{{localize "DOWNTIME_MANAGER.Station.Interval"}}: {{intervalProgress}} / {{rollInterval}}</small></div>
            {{#if awaitingCompletionCheck}}<div class="sc-completion-check"><strong>{{localize "DOWNTIME_MANAGER.Project.CompletionCheck"}} · DC {{completionDC}}</strong>{{#if completionCheckFailed}}<small>{{localize "DOWNTIME_MANAGER.Project.CompletionRetryCost"}}: {{completionRetryCost}} {{localize "DOWNTIME_MANAGER.Station.Downtime"}}</small>{{/if}}</div><select data-completion-check-for="{{uuid}}">{{#each checks}}<option value="{{id}}">{{label}}</option>{{/each}}</select><button type="button" data-action="completionRoll" data-uuid="{{uuid}}" {{#unless canCompletionRoll}}disabled{{/unless}}><i class="fa-solid fa-flag-checkered"></i> {{localize "DOWNTIME_MANAGER.Project.RollCompletionCheck"}}</button>
            {{else}}{{#if pendingRoll}}<select data-check-for="{{uuid}}">{{#each checks}}<option value="{{id}}">{{label}}</option>{{/each}}</select><button type="button" data-action="roll" data-uuid="{{uuid}}" {{#unless canRoll}}disabled{{/unless}}><i class="fa-solid fa-dice-d20"></i> {{localize "DOWNTIME_MANAGER.Actions.Roll"}}</button>
            {{else}}{{#if showCheckSelection}}<select data-check-for="{{uuid}}">{{#each checks}}<option value="{{id}}">{{label}}</option>{{/each}}</select>{{/if}}<input class="sc-downtime-input" type="number" data-downtime-for="{{uuid}}" value="{{maxInvestment}}" min="0.000001" max="{{maxInvestment}}" step="any"><button type="button" data-action="invest" data-uuid="{{uuid}}" {{#unless canInvest}}disabled{{/unless}}>{{localize "DOWNTIME_MANAGER.Actions.Invest"}}</button>{{/if}}{{/if}}<button type="button" data-action="deactivate" data-uuid="{{uuid}}" class="sc-deactivate-project"><i class="fa-solid fa-pause"></i> {{localize "DOWNTIME_MANAGER.Actions.Deactivate"}}</button>
          {{else}}{{#if paused}}<div class="sc-project-progress"><div><i class="fa-solid fa-pause"></i> {{progress}} / {{requiredProgress}} ({{percent}}%)</div><progress max="{{requiredProgress}}" value="{{progress}}"></progress><small class="notes">{{localize "DOWNTIME_MANAGER.Station.Interval"}}: {{intervalProgress}} / {{rollInterval}}</small></div>{{else}}{{#if completed}}<div class="sc-project-state">{{localize "DOWNTIME_MANAGER.Project.Completed"}}</div>{{else}}<div class="sc-project-state"></div>{{/if}}{{/if}}{{#unless paused}}<label class="sc-quantity-control"><span>{{localize "DOWNTIME_MANAGER.Project.Quantity"}}</span><input type="number" data-quantity-for="{{uuid}}" value="1" min="1" step="1"></label>{{/unless}}<button type="button" data-action="start" data-uuid="{{uuid}}" {{#unless canStart}}disabled{{/unless}}>{{#if paused}}<i class="fa-solid fa-play"></i> {{localize "DOWNTIME_MANAGER.Actions.Resume"}}{{else}}{{localize "DOWNTIME_MANAGER.Actions.Start"}}{{/if}}</button>{{/if}}
        </div>

        {{#if lastResult}}<div class="sc-last-investment"><strong>{{localize "DOWNTIME_MANAGER.Station.LastInvestment"}}</strong><div class="sc-last-investment-summary"><span><strong>{{localize "DOWNTIME_MANAGER.Station.InvestedDowntime"}}:</strong> {{lastResult.downtime}}</span>{{#if lastResult.hasRoll}}<span><strong>{{localize "DOWNTIME_MANAGER.Station.RollResult"}}:</strong> {{#if lastResult.label}}{{lastResult.label}} · {{/if}}{{lastResult.rollTotal}} (d20: {{lastResult.natural}})</span>{{/if}}<span><strong>{{localize "DOWNTIME_MANAGER.Station.ProgressChange"}}:</strong> {{lastResult.progress}}</span>{{#if lastResult.actorValueEnabled}}{{#if lastResult.hasActorValueResult}}<span><strong>{{../actorValueLabel}}:</strong> {{lastResult.actorValueChange}} ({{lastResult.actorValueBefore}} → {{lastResult.actorValueAfter}})</span>{{/if}}{{/if}}{{#if lastResult.showRewardSummary}}<span><strong>{{localize "DOWNTIME_MANAGER.Station.Reward"}}:</strong> {{#if lastResult.rewards}}{{#each lastResult.rewards}}{{#unless @first}}, {{/unless}}{{name}} × {{quantity}}{{/each}}{{else}}{{localize "DOWNTIME_MANAGER.Common.None"}}{{/if}}</span>{{/if}}</div><details><summary>{{localize "DOWNTIME_MANAGER.Station.CalculationExplanation"}}</summary><code>{{lastResult.formula}}</code><dl class="sc-calculation-parts"><div><dt>{{localize "DOWNTIME_MANAGER.Calculation.Downtime"}}: {{lastResult.downtime}}</dt><dd>{{localize "DOWNTIME_MANAGER.Calculation.DowntimeHelp"}}</dd></div>{{#each lastResult.parts}}<div><dt>{{label}}: {{value}}</dt><dd>{{explanation}}</dd></div>{{/each}}</dl></details></div>{{/if}}
      </article>
    {{else}}<p class="notes">{{localize "DOWNTIME_MANAGER.Station.NoProjects"}}</p>{{/each}}</div>
  {{/if}}
</div>
