<div class="sc-body sc-dashboard-body">
  <div class="sc-title-row">
    <h2>{{localize "DOWNTIME_MANAGER.Dashboard.Title"}}</h2>
    <div class="sc-section-actions"><button type="button" data-action="openProjectLibrary"><i class="fa-solid fa-scroll"></i> {{localize "DOWNTIME_MANAGER.ProjectLibrary.Title"}}</button><button type="button" data-action="openSessions"><i class="fa-solid fa-campground"></i> {{localize "DOWNTIME_MANAGER.Session.Title"}}</button><button type="button" data-action="refresh"><i class="fa-solid fa-rotate"></i> {{localize "DOWNTIME_MANAGER.Dashboard.Refresh"}}</button></div>
  </div>
  <div class="sc-dashboard-summary">
    <span><strong>{{localize "DOWNTIME_MANAGER.Dashboard.Stations"}}:</strong> {{stations.length}}</span>
    <span><strong>{{localize "DOWNTIME_MANAGER.Dashboard.Active"}}:</strong> {{activeCount}}</span>
    <span><strong>{{localize "DOWNTIME_MANAGER.Dashboard.PendingRolls"}}:</strong> {{rollCount}}</span>
    <span><strong>{{localize "DOWNTIME_MANAGER.Dashboard.Completed"}}:</strong> {{completedCount}}</span>
  </div>
  <details class="sc-dashboard-projects" open><summary>{{localize "DOWNTIME_MANAGER.Dashboard.ProjectOverview"}}</summary><div class="sc-dashboard-projects-body"><div class="sc-dashboard-stations">{{#each stations}}<button type="button" data-action="openStation" data-uuid="{{uuid}}" {{#unless enabled}}class="disabled"{{/unless}}><i class="fa-solid fa-screwdriver-wrench"></i> {{name}}</button>{{/each}}</div>
  <div class="sc-dashboard-table">
    <div class="sc-dashboard-row header"><span>{{localize "DOWNTIME_MANAGER.Dashboard.Character"}}</span><span>{{localize "DOWNTIME_MANAGER.Dashboard.Station"}}</span><span>{{localize "DOWNTIME_MANAGER.Dashboard.Project"}}</span><span>{{localize "DOWNTIME_MANAGER.Dashboard.Progress"}}</span><span>{{localize "DOWNTIME_MANAGER.Dashboard.StatusLabel"}}</span><span></span></div>
    {{#each rows}}<div class="sc-dashboard-row"><span class="sc-dashboard-actor"><img src="{{actorImg}}" alt="">{{actorName}}</span><span>{{#if stationAvailable}}<button type="button" data-action="openStation" data-uuid="{{stationUuid}}">{{stationName}}</button>{{else}}{{stationName}}{{/if}}</span><span>{{projectName}}</span><span><progress max="100" value="{{percent}}"></progress><small>{{progress}} / {{requiredProgress}} ({{percent}}%)</small></span><span class="status {{status}}">{{statusLabel}}</span><button type="button" class="danger sc-dashboard-remove" data-action="removeProject" data-actor-uuid="{{actorUuid}}" data-state-id="{{stateId}}" data-station-uuid="{{stationUuid}}" data-project-uuid="{{projectUuid}}" data-project-name="{{projectName}}" title="{{localize 'DOWNTIME_MANAGER.Dashboard.RemoveProject'}}"><i class="fa-solid fa-trash"></i></button></div>{{else}}<p class="notes">{{localize "DOWNTIME_MANAGER.Dashboard.Empty"}}</p>{{/each}}
  </div></div></details>
  <details class="sc-dashboard-downtime" open><summary>{{localize "DOWNTIME_MANAGER.Dashboard.DirectDowntime"}}</summary><div class="sc-dashboard-downtime-body"><div class="sc-dashboard-character-grid">{{#each characters}}<label class="checkbox"><input type="checkbox" name="directDowntimeActors" value="{{uuid}}"><img src="{{img}}" alt=""><span><strong>{{name}}</strong><small>{{localize "DOWNTIME_MANAGER.Dashboard.CurrentDowntime"}}: {{downtime}}</small></span></label>{{else}}<p class="notes">{{localize "DOWNTIME_MANAGER.Dashboard.Errors.NoCharacters"}}</p>{{/each}}</div><div class="sc-dashboard-grant-actions"><label><span>{{localize "DOWNTIME_MANAGER.Dashboard.Amount"}}</span><input type="number" name="directDowntimeAmount" value="1" min="0.000001" step="any"></label><button type="button" data-action="grantSelectedDowntime"><i class="fa-solid fa-user-check"></i> {{localize "DOWNTIME_MANAGER.Dashboard.GrantSelected"}}</button><button type="button" data-action="grantAllDowntime"><i class="fa-solid fa-users"></i> {{localize "DOWNTIME_MANAGER.Dashboard.GrantAll"}}</button></div>{{#if lastDirectAll}}<p class="sc-dashboard-last-grant"><i class="fa-solid fa-clock-rotate-left"></i> {{localize "DOWNTIME_MANAGER.Dashboard.LastGrantAll"}}: <strong>{{date}}</strong> · {{amount}} {{localize "DOWNTIME_MANAGER.Station.Downtime"}} · {{count}} {{localize "DOWNTIME_MANAGER.Dashboard.Characters"}}{{#if userName}} · {{userName}}{{/if}}</p>{{/if}}</div></details>
</div>
