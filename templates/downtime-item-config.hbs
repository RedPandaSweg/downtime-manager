<div class="sc-body sc-downtime-item-body">
  <div class="sc-downtime-item-heading"><img src="{{item.img}}" alt=""><div><h2>{{item.name}}</h2><p class="notes">{{localize "DOWNTIME_MANAGER.DowntimeItem.Hint"}}</p></div></div>
  {{#if project}}<p class="notification info">{{localize "DOWNTIME_MANAGER.DowntimeItem.IsProject"}}</p>{{else}}{{#if configured}}
    {{#if nativeUse}}<p class="notification info">{{localize "DOWNTIME_MANAGER.DowntimeItem.NativeUse"}}</p>{{/if}}<div class="sc-downtime-item-fields"><label><span>{{localize "DOWNTIME_MANAGER.DowntimeItem.Amount"}}</span><input type="number" name="amount" value="{{config.amount}}" min="0.000001" step="any" {{#unless canConfigure}}disabled{{/unless}}></label>{{#unless nativeUse}}<label class="checkbox"><input type="checkbox" name="consume" {{checked config.consume}} {{#unless canConfigure}}disabled{{/unless}}> {{localize "DOWNTIME_MANAGER.DowntimeItem.Consume"}}</label>{{/unless}}<label class="checkbox"><input type="checkbox" name="chatMessage" {{checked config.chatMessage}} {{#unless canConfigure}}disabled{{/unless}}> {{localize "DOWNTIME_MANAGER.DowntimeItem.ChatMessage"}}</label></div>
    <div class="sc-config-footer">{{#if canConfigure}}<button type="button" class="danger" data-action="remove"><i class="fa-solid fa-trash"></i> {{localize "DOWNTIME_MANAGER.DowntimeItem.Remove"}}</button><button type="button" data-action="save"><i class="fa-solid fa-floppy-disk"></i> {{localize "DOWNTIME_MANAGER.Actions.Save"}}</button>{{/if}}{{#if canRedeem}}<button type="button" data-action="redeem"><i class="fa-solid fa-hourglass-half"></i> {{localize "DOWNTIME_MANAGER.DowntimeItem.Redeem"}}</button>{{/if}}</div>
  {{else}}{{#if canConfigure}}<div class="sc-item-role-choice"><button type="button" data-action="makeProject"><i class="fa-solid fa-scroll"></i><strong>{{localize "DOWNTIME_MANAGER.DowntimeItem.MakeProject"}}</strong><small>{{localize "DOWNTIME_MANAGER.DowntimeItem.MakeProjectHint"}}</small></button><button type="button" data-action="makeDowntimeItem"><i class="fa-solid fa-hourglass-half"></i><strong>{{localize "DOWNTIME_MANAGER.DowntimeItem.MakeItem"}}</strong><small>{{localize "DOWNTIME_MANAGER.DowntimeItem.MakeItemHint"}}</small></button></div>{{/if}}{{/if}}{{/if}}
</div>
