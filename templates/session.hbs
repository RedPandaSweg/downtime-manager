<div class="sc-body sc-session-body">
  <div class="sc-title-row"><h2>{{localize "DOWNTIME_MANAGER.Session.Title"}}</h2><div class="sc-section-actions"><button type="button" data-action="configureRewards"><i class="fa-solid fa-gift"></i> {{localize "DOWNTIME_MANAGER.Session.ConfigureRewards"}}</button>{{#if historyEnabled}}<button type="button" data-action="history"><i class="fa-solid fa-book"></i> {{localize "DOWNTIME_MANAGER.Session.History"}}</button>{{/if}}</div></div>
  {{#if awarded}}<p class="notification info">{{localize "DOWNTIME_MANAGER.Session.AlreadyAwarded"}}</p>{{/if}}
  <div class="sc-session-fields">{{#if historyEnabled}}<label><span>{{localize "DOWNTIME_MANAGER.Session.Name"}}</span><input type="text" name="title" value="{{active.title}}" {{#if awarded}}disabled{{/if}}></label>{{/if}}<label><span>{{localize "DOWNTIME_MANAGER.Session.Multiplier"}}</span><select name="multiplier" {{#if awarded}}disabled{{/if}}>{{#each multipliers}}<option value="{{value}}" {{#if selected}}selected{{/if}}>×{{value}}</option>{{/each}}</select></label>{{#if historyEnabled}}<label class="wide"><span>{{localize "DOWNTIME_MANAGER.Session.Summary"}}</span><textarea name="summary" {{#if awarded}}disabled{{/if}}>{{active.summary}}</textarea></label>{{/if}}</div>
  <details class="sc-session-players" open>
    <summary>{{localize "DOWNTIME_MANAGER.Session.PlayerSelection"}}</summary>
    <div class="sc-session-actions"><button type="button" data-action="selectConnected" {{#if awarded}}disabled{{/if}}>{{localize "DOWNTIME_MANAGER.Session.SelectConnected"}}</button><button type="button" data-action="selectTokens" {{#if awarded}}disabled{{/if}}>{{localize "DOWNTIME_MANAGER.Session.SelectTokens"}}</button></div>
    <div class="sc-session-actors">{{#each actors}}<label class="sc-session-actor"><input type="checkbox" name="actors" value="{{uuid}}" {{checked selected}} {{#if ../awarded}}disabled{{/if}}><img class="sc-session-actor-img" src="{{img}}" alt=""><span class="sc-session-actor-name"><strong>{{name}}</strong><small>{{localize "DOWNTIME_MANAGER.Session.Level"}} {{level}} · {{localize "DOWNTIME_MANAGER.Session.Available"}}: {{downtime}}</small></span><span class="sc-session-reward"><span class="sc-session-reward-items">{{#each rewardItems}}<span class="sc-session-reward-chip {{#unless selected}}disabled{{/unless}}"><img src="{{img}}" alt=""><span>{{name}}</span><strong>×{{quantity}}</strong></span>{{else}}<span class="notes">{{localize "DOWNTIME_MANAGER.Common.None"}}</span>{{/each}}</span><small>{{localize "DOWNTIME_MANAGER.Session.Milestones"}}: {{milestones}} · {{localize "DOWNTIME_MANAGER.Session.Passive"}}: {{passive}}</small></span></label>{{else}}<p class="notes">{{localize "DOWNTIME_MANAGER.Session.NoActors"}}</p>{{/each}}</div>
  </details>
  <fieldset class="sc-session-distribution"><legend>{{localize "DOWNTIME_MANAGER.Session.Distribute"}}</legend><div class="sc-session-column-toggles">{{#each rewardColumns}}<label class="checkbox"><input type="checkbox" name="rewardColumns" value="{{index}}" {{checked selected}} {{#if ../awarded}}disabled{{/if}}><img src="{{img}}" alt=""><span>{{name}}</span></label>{{/each}}<label class="checkbox sc-session-milestone-toggle"><input type="checkbox" name="awardMilestones" {{checked awardMilestones}} {{#if awarded}}disabled{{/if}}> <i class="fa-solid fa-flag"></i><span>{{localize "DOWNTIME_MANAGER.Session.DistributeMilestones"}}</span></label></div></fieldset>
  <div class="sc-session-footer">{{#if awarded}}<button type="button" data-action="newSession"><i class="fa-solid fa-plus"></i> {{localize "DOWNTIME_MANAGER.Session.New"}}</button>{{else}}{{#if historyEnabled}}<button type="button" data-action="save"><i class="fa-solid fa-floppy-disk"></i> {{localize "DOWNTIME_MANAGER.Session.Save"}}</button>{{/if}}<button type="button" data-action="award"><i class="fa-solid fa-gift"></i> {{localize "DOWNTIME_MANAGER.Session.Award"}}</button>{{/if}}<label><span>{{localize "DOWNTIME_MANAGER.Session.Settlement"}}</span>{{#if passiveWeekly}}<input type="week" name="period" value="{{periodKey}}">{{else}}<input type="month" name="period" value="{{periodKey}}">{{/if}}</label><button type="button" data-action="settle">{{localize "DOWNTIME_MANAGER.Session.Settle"}}</button></div>
</div>
