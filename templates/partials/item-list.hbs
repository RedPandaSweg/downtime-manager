<div class="item-drop-zone" data-list="{{listName}}" title="{{localize 'DOWNTIME_MANAGER.Tooltips.Items.Drop'}}">{{localize dropLabel}}</div>
<div class="sc-list">{{#each entries}}<div class="sc-row"><img src="{{img}}" alt=""><span class="grow">{{name}}</span><input type="number" name="{{../listName}}.{{@index}}.quantity" value="{{quantity}}" min="{{#if ../allowZero}}0{{else}}0.000001{{/if}}" step="any" title="{{localize 'DOWNTIME_MANAGER.Tooltips.Items.Quantity'}}"><button type="button" data-action="removeEntry" data-list="{{../listName}}" data-index="{{@index}}" title="{{localize 'DOWNTIME_MANAGER.Tooltips.Actions.RemoveEntry'}}"><i class="fa-solid fa-trash"></i></button></div>{{else}}<p class="notes">{{localize "DOWNTIME_MANAGER.Common.None"}}</p>{{/each}}</div>
