<div class="sc-body sc-project-library-body">
  <div class="sc-title-row"><div><h2>{{localize "DOWNTIME_MANAGER.ProjectLibrary.Title"}}</h2><p class="notes">{{localize "DOWNTIME_MANAGER.ProjectLibrary.Hint"}}</p></div><button type="button" data-action="refresh"><i class="fa-solid fa-rotate"></i> {{localize "DOWNTIME_MANAGER.Dashboard.Refresh"}}</button></div>
  <div class="sc-project-library-actions"><button type="button" data-action="createProject"><i class="fa-solid fa-plus"></i> {{localize "DOWNTIME_MANAGER.ProjectLibrary.Create"}}</button><span class="sc-template-picker"><select data-project-template aria-label="{{localize 'DOWNTIME_MANAGER.Project.Template'}}">{{#each templates}}<option value="{{id}}">{{name}}</option>{{/each}}</select><button type="button" data-action="createTemplate"><i class="fa-solid fa-wand-magic-sparkles"></i> {{localize "DOWNTIME_MANAGER.Project.CreateFromTemplate"}}</button></span></div>
  <div class="sc-project-library-list">{{#each projects}}<article class="sc-row sc-library-project"><img src="{{img}}" alt=""><div class="grow"><strong>{{name}}</strong><div class="sc-library-meta"><span>{{localize "DOWNTIME_MANAGER.Project.RequiredProgress"}}: {{requiredProgress}}</span><span>{{localize "DOWNTIME_MANAGER.ProjectLibrary.Rewards"}}: {{rewardCount}}</span><span>{{#if repeatable}}{{localize "DOWNTIME_MANAGER.Project.Repeatable"}}{{else}}{{localize "DOWNTIME_MANAGER.ProjectLibrary.OneTime"}}{{/if}}</span></div><small>{{localize "DOWNTIME_MANAGER.ProjectLibrary.Stations"}}: {{#if stations.length}}{{#each stations}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}{{localize "DOWNTIME_MANAGER.ProjectLibrary.Unassigned"}}{{/if}}{{#if progressCount}} · {{localize "DOWNTIME_MANAGER.ProjectLibrary.ActiveProgress"}}: {{progressCount}}{{/if}}</small></div><div class="sc-list-controls"><button type="button" data-action="editProject" data-uuid="{{uuid}}" title="{{localize 'DOWNTIME_MANAGER.Actions.Configure'}}"><i class="fa-solid fa-pen"></i></button><button type="button" class="danger" data-action="deleteProject" data-uuid="{{uuid}}" title="{{localize 'DOWNTIME_MANAGER.ProjectLibrary.Delete'}}"><i class="fa-solid fa-trash"></i></button></div></article>{{else}}<p class="notes">{{localize "DOWNTIME_MANAGER.ProjectLibrary.Empty"}}</p>{{/each}}</div>
</div>
